rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && (
        request.auth.uid == 'JZgMG6xdwAYInXsdciaGj6qNAsG2' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('canAccessSuperiorAdmin', false) == true)
      );
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSessionManager() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'session_manager';
    }

    function isSameCommittee(committee) {
      return committee == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.defaultCommittee;
    }

    // WARNING:
    // Some rules are intentionally relaxed to facilitate development.
    // In a production environment, 'allow read/write: if true' should be replaced 
    // with strict owner/admin-only checks.

    // Participants
    match /participants/{participantId} {
      allow read: if true;
      allow create: if isOwner() || isAdmin();
      allow update: if isOwner() || isAdmin() || (isSessionManager() && isSameCommittee(resource.data.committee));
      allow delete: if isOwner() || (isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.canDeleteParticipants == true);
    }

    // Staff members
    match /staff_members/{staffMemberId} {
      allow read: if true;
      allow create: if isOwner() || (isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.canCreateStaff == true);
      allow update: if isOwner() || (isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.canEditStaff == true);
      allow delete: if isOwner() || (isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.canDeleteStaff == true);
    }

    // System collections (read-only for most, write for owner/admin)
    match /system_schools/{schoolId} { allow read: if true; allow write: if isOwner() || isAdmin(); }
    match /system_committees/{committeeId} { allow read: if true; allow write: if isOwner() || isAdmin(); }
    match /system_staff_teams/{teamId} { allow read: if true; allow write: if isOwner() || isAdmin(); }
    match /system_config/{settingId} { allow read: if true; allow write: if isOwner() || isAdmin(); }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwner() || isAdmin());
      allow update: if isSignedIn() && (
        isOwner() ||
        // Allow users (including Session Managers) to update ONLY their own session data and notes
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sessionNotes', 'sessionState', 'updatedAt'])) ||
        // Allow admins to update user data if they are not the same user (standard admin management)
        (isAdmin() && request.auth.uid != userId) 
      );
      allow create, delete: if isOwner();
    }

    // System logs
    match /system_logs/{logId} {
      allow read: if isOwner() || (isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.canAccessLogs == true);
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isOwner();
    }
  }
}

