rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Safely check for a permission flag in the user's permissions map
    function hasPermission(perm) {
      return isSignedIn() && hasUserDoc() && getUserData().get('permissions', {}).get(perm, false) == true;
    }

    // Check for high-level owner access (static UID or explicit flag)
    function isOwner() {
      return isSignedIn() && (
        request.auth.uid == 'JZgMG6xdwAYInXsdciaGj6qNAsG2' || 
        (hasUserDoc() && getUserData().get('canAccessSuperiorAdmin', false) == true)
      );
    }

    function isAdmin() {
      return isSignedIn() && hasUserDoc() && getUserData().role == 'admin';
    }

    function isSessionManager() {
      return isSignedIn() && hasUserDoc() && getUserData().role == 'session_manager';
    }

    function isSameCommittee(committee) {
      return isSignedIn() && hasUserDoc() && committee == getUserData().get('defaultCommittee', '');
    }

    // --- Collection Rules ---

    // Participants
    match /participants/{participantId} {
      allow read: if true;
      allow create: if isOwner() || isAdmin();
      allow update: if isOwner() 
                    || hasPermission('canEditParticipants') 
                    || hasPermission('canEditParticipantStatus')
                    || (isSessionManager() && isSameCommittee(resource.data.committee));
      allow delete: if isOwner() || hasPermission('canDeleteParticipants');
    }

    // Staff members
    match /staff_members/{staffMemberId} {
      allow read: if true;
      allow create: if isOwner() || hasPermission('canCreateStaff');
      allow update: if isOwner() || hasPermission('canEditStaff') || hasPermission('canEditStaffStatus');
      allow delete: if isOwner() || hasPermission('canDeleteStaff');
    }

    // System collections
    match /system_schools/{schoolId} { allow read: if true; allow write: if isOwner() || isAdmin(); }
    match /system_committees/{committeeId} { allow read: if true; allow write: if isOwner() || isAdmin(); }
    match /system_staff_teams/{teamId} { allow read: if true; allow write: if isOwner() || isAdmin(); }
    match /system_config/{settingId} { allow read: if true; allow write: if isOwner() || isAdmin(); }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwner() || isAdmin());
      allow update: if isSignedIn() && (
        isOwner() ||
        // Allow users to update ONLY their own session data and notes
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sessionNotes', 'sessionState', 'updatedAt', 'notificationPreferences'])) ||
        // Allow admins to update user data if they are not the same user
        (isAdmin() && request.auth.uid != userId) 
      );
      allow create, delete: if isOwner();
    }

    // System logs
    match /system_logs/{logId} {
      allow read: if isOwner() || hasPermission('canAccessLogs');
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isOwner();
    }
  }
}
